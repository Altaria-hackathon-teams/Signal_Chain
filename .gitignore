# ─── Dependency / build artifacts ──────────────────────────────────────────
node_modules/
**/node_modules/
dist/
dist-ssr/
build/
.cache/
.parcel-cache/
*.tsbuildinfo

# ─── Vite / React frontend ─────────────────────────────────────────────────
frontend/dist/
frontend/.vite/
frontend/.eslintcache

# ─── Python / Flask ml-engine ──────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
pytest-cache-files-*/
*.egg-info/
.coverage
htmlcov/
.tox/

# Virtual environments
.venv/
**/.venv/
venv/
**/venv/
env/
**/env/
.python-version

# ─── Soroban / Rust contracts ──────────────────────────────────────────────
contracts/**/target/
contracts/**/Cargo.lock.bak
*.wasm
!contracts/**/src/**/*.wasm

# ─── Database / runtime data ───────────────────────────────────────────────
database/*.db
database/*.db-journal
database/*.db-shm
database/*.db-wal
*.sqlite
*.sqlite3

# ─── Secrets / environment files ───────────────────────────────────────────
.env
.env.local
.env.*.local
**/.env
!**/.env.example

# ─── Logs ──────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Editor / OS noise ─────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
.DS_Store
Thumbs.db

# ─── Misc ──────────────────────────────────────────────────────────────────
*.tgz
*.tar.gz
.tmp/
.temp/
coverage/
