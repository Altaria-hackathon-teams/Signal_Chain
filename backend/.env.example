# Soroban contract ID (returned by `stellar contract deploy`).
# See contracts/README.md for deployment steps.
REVIEW_CONTRACT_ID=

# Testnet secret key of the funded account that pays Soroban fees when the
# backend submits a review on behalf of an authenticated reviewer.
# Generate with `stellar keys generate --global deployer --network testnet --fund`
# and copy the output of `stellar keys show deployer` here.
SUBMITTER_SECRET_KEY=

# Optional override (defaults to Stellar testnet RPC).
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Runtime settings.
# PORT=3001
# CORS_ORIGIN=http://localhost:5173
# HORIZON_URL=https://horizon-testnet.stellar.org
# JSON_BODY_LIMIT=64kb
